# Cardea — credential-injecting reverse proxy
# Copy this file to config.toml and enable the modules you need.

[modules]

# Telegram Bot API proxy
# Env vars: TELEGRAM_TOKEN_FOR_BOT_<ALIAS> (one per bot alias)
telegram = false

# GitHub git HTTPS proxy
# Env vars: GITHUB_TOKEN
github = false

# Gmail API proxy
# Env vars: GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET, GMAIL_REFRESH_TOKEN
gmail = false
