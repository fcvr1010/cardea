# Cardea — credential-injecting reverse proxy
# Copy this file to config.toml and enable the modules you need.

[modules]

# Telegram Bot API proxy
# Secrets: cardea_telegram_token_for_bot_<alias> (one per bot alias)
telegram = false

# Gmail API proxy
# Secrets: cardea_gmail_client_id, cardea_gmail_client_secret, cardea_gmail_refresh_token
gmail = false

# Email proxy (IMAP/SMTP — no OAuth needed, just an app password)
# Secrets: cardea_email_password
email = false


# ── Per-module configuration ─────────────────────────────────────────────────

[email]
address = "your@email.com"
imap_server = "imap.gmail.com"
smtp_server = "smtp.gmail.com"


# ── Per-module endpoint control ──────────────────────────────────────────────
# Add a section named after the module to selectively disable specific
# endpoints while keeping the rest of the module active.
#
# Example — disable the Gmail send endpoint:
#
# [gmail]
# disabled_endpoints = ["send"]
#
# The value is a list of path suffixes (without the module prefix).
# "send" disables /gmail/send, "reply" would disable /gmail/reply/{...}, etc.


# ── Generic HTTP services ────────────────────────────────────────────────────
# Define config-driven reverse proxies for any REST API.  Each [services.NAME]
# block creates a route: <prefix>/* → <upstream>/* with credential injection.
#
# Supported auth types:
#   bearer  — Authorization: Bearer <secret>
#   basic   — Authorization: Basic base64(<username>:<secret>)
#   header  — Custom header (set auth.header_name)
#   query   — Query parameter (set auth.param_name)
#   none    — No credential injection
#
# Adding a new service is just 4 lines + a podman secret:
#
#   [services.my-api]
#   prefix = "/my-api"
#   upstream = "https://api.example.com"
#   auth = { type = "bearer", secret = "cardea_my_api_token" }
#
# Services are matched by prefix length (longest first), so /github/api
# matches before /github.

[services.github-api]
prefix = "/github/api"
upstream = "https://api.github.com"
auth = { type = "bearer", secret = "cardea_github_token" }

[services.github-git]
prefix = "/github"
upstream = "https://github.com"
auth = { type = "basic", username = "x-access-token", secret = "cardea_github_token" }


# ── Browser credential manager ───────────────────────────────────────────────
# Auto-fill login forms via CDP (Chrome DevTools Protocol) without the
# AI agent ever seeing the actual credentials.
#
# Requires: the Chromium instance exposes a CDP port reachable from this
# container (e.g. via Compose bridge networking).
#
# Secret format (JSON): {"username": "...", "password": "..."}
# Key names in "fields" must match keys in the secret JSON.

# [browser]
# cdp_endpoint = "ws://vito:9222"
#
# [browser.sites.github]
# url_pattern = "github.com/login"
# secret = "browser_github"
# fields = [
#   { selector = "#login_field", key = "username" },
#   { selector = "#password", key = "password" },
# ]
