# Cardea — credential-injecting reverse proxy
# Copy this file to config.toml and enable the modules you need.

[modules]

# Telegram Bot API proxy
# Secrets: cardea_telegram_token_for_bot_<alias> (one per bot alias)
telegram = false

# GitHub git HTTPS proxy
# Secrets: cardea_github_token
github = false

# Gmail API proxy
# Secrets: cardea_gmail_client_id, cardea_gmail_client_secret, cardea_gmail_refresh_token
gmail = false

# Email proxy (IMAP/SMTP — no OAuth needed, just an app password)
# Secrets: cardea_email_password
email = false


# ── Per-module configuration ─────────────────────────────────────────────────

[email]
address = "your@email.com"
imap_server = "imap.gmail.com"
smtp_server = "smtp.gmail.com"


# ── Per-module endpoint control ──────────────────────────────────────────────
# Add a section named after the module to selectively disable specific
# endpoints while keeping the rest of the module active.
#
# Example — disable the Gmail send endpoint:
#
# [gmail]
# disabled_endpoints = ["send"]
#
# The value is a list of path suffixes (without the module prefix).
# "send" disables /gmail/send, "reply" would disable /gmail/reply/{...}, etc.
